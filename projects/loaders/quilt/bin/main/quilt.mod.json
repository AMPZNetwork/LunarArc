{
  "schema_version": 1,
  "quilt_loader": {
    "group": "io.ampznetwork",
    "id": "lunararc",
    "version": "${version}",
    "metadata": {
      "name": "${project_name}",
      "description": "LunarArc Hybrid Server Core",
      "contributors": {
        "Ampz Network": "Owner"
      },
      "contact": {
        "homepage": "https://lunararc.net",
        "sources": "https://github.com/AmpzNetwork/LunarArc"
      },
      "license": "GPL-3.0-only",
      "icon": "assets/lunararc/icon.png"
    },
    "intermediate_mappings": "net.fabricmc:intermediary",
    "entrypoints": {
      "main": "io.ampznetwork.lunararc.quilt.LunarArcQuilt"
    },
    "mixin": "mixins.lunararc.common.json",
    "depends": [
      {
        "quilt_loader": ">=${quilt_loader}",
        "minecraft": ">=${minecraft}"
      }
    ]
  }
}
